{
  "base_model": "TinyLlama/TinyLlama-1.1B-Chat-v1.0",
  "technique": "qlora",
  "lora_r": 16,
  "lora_alpha": 32,
  "lora_dropout": 0.05,
  "lora_target_modules": ["q_proj", "v_proj", "k_proj", "o_proj"],
  "dataset_path": "data/train.jsonl",
  "data_format": "instruction",
  "max_seq_len": 512,
  "val_split": 0.1,
  "epochs": 3,
  "batch_size": 4,
  "grad_accumulation": 4,
  "learning_rate": 2e-4,
  "warmup_ratio": 0.03,
  "lr_scheduler": "cosine",
  "weight_decay": 0.01,
  "eval_steps": 50,
  "save_steps": 100,
  "logging_steps": 10,
  "early_stopping_patience": 3,
  "output_dir": "outputs/tinyllama-finetuned",
  "merge_weights": true,
  "push_to_hub": false
}
